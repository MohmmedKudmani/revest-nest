generator client {
  provider              = "prisma-client"
  output                = "../generated"
  moduleFormat          = "cjs"
  runtime               = "nodejs"
  importFileExtension   = ""
}

datasource db {
  provider = "sqlite"
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
